        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "oxlint": "^1.74.0",
        "prettier": "^3.9.5",
        "typescript": "~7.0.2",
        "vite": "^8.1.5",
        "vitest": "^4.1.10"
    }
